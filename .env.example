# ============================================
# Prodory Platform - Environment Configuration
# ============================================

# Supabase Configuration
# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database
DATABASE_URL=postgresql://postgres:password@db:5432/prodory

# Application Settings
NODE_ENV=production
APP_NAME=Prodory Platform
APP_VERSION=1.0.0

# FinOps Dashboard
FINOPS_DASHBOARD_PORT=3000
FINOPS_API_URL=http://data-finops-agent:8000

# Data FinOps Agent
DATA_FINOPS_PORT=8000
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AZURE_SUBSCRIPTION_ID=your-azure-sub
GCP_PROJECT_ID=your-gcp-project

# Cloud Sentinel
SENTINEL_PORT=9090
PROMETHEUS_RETENTION=30d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Kubernetes-in-a-Box
K3S_TOKEN=prodory-k3s-secret-token
K3S_NODE_PORT=6443

# Storage Autoscaler
STORAGE_AUTOSCALER_PORT=8080
KUBECONFIG_PATH=/root/.kube/config

# VMware Migration
VMWARE_MIGRATION_PORT=8081
VSPHERE_HOST=vcenter.your-domain.com
VSPHERE_USER=administrator@vsphere.local
VSPHERE_PASSWORD=your-password

# VM to Container Migration
VM_CONTAINER_PORT=8082
DOCKER_HOST=unix:///var/run/docker.sock

# Security
ENCRYPTION_KEY=your-32-character-encryption-key
JWT_EXPIRY=24h
